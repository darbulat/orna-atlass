DATABASE_URL=postgresql+asyncpg://orna:orna@postgres:5432/orna_atlas
REDIS_URL=redis://redis:6379/0
NEXT_PUBLIC_API_URL=http://localhost:8000
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_PRIVATE_BUCKET=orna-audio-private
S3_PUBLIC_BUCKET=orna-media-public
S3_ACCESS_KEY_ID=orna
S3_SECRET_ACCESS_KEY=ornaorna
S3_PRESIGN_EXPIRES_SECONDS=900
AUDIO_JOB_TIMEOUT_SECONDS=600
AUDIO_JOB_RESULT_TTL_SECONDS=3600
MEDIA_RETENTION_DAYS=30
APP_ENVIRONMENT=development
AUDIO_JOB_TIMEOUT_PER_HOUR_SECONDS=3600
AUDIO_JOB_MAX_TIMEOUT_SECONDS=21600
AUDIO_JOB_MAX_RETRIES=2
AUDIO_JOB_RETRY_INTERVAL_SECONDS=60
PIPELINE_STALE_AFTER_SECONDS=25200
WORKER_METRICS_PORT=9101
AUTH_SECRET_KEY=development-only-change-me-32-bytes
AUTH_SIGNING_ALGORITHM=HS256
AUTH_KEY_ID=orna-primary
# Production RS256 deployments provide PEM AUTH_PRIVATE_KEY and a rotation-ready AUTH_JWKS_JSON.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
LOCAL_ADMIN_ENABLED=true
AUTH_RATE_LIMIT=10
PLAYBACK_RATE_LIMIT=30
SEARCH_RATE_LIMIT=60
RATE_LIMIT_WINDOW_SECONDS=60
