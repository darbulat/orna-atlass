{
  "name": "orna-atlas-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/copy-cesium-assets.mjs",
    "dev": "next dev",
    "build": "next build",
    "api:export": "cd .. && python -m orna_atlas.app.scripts.export_openapi --output web/openapi.json",
    "api:generate": "npm run api:export && openapi-typescript openapi.json -o lib/api/generated.ts",
    "api:check": "npm run api:generate && git diff --exit-code -- openapi.json lib/api/generated.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "cesium": "1.140.0",
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.4",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.5.3"
  }
}
